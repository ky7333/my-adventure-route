{
  "name": "my-adventure-route",
  "private": true,
  "version": "0.1.1",
  "packageManager": "pnpm@10.6.2",
  "scripts": {
    "dev": "pnpm --filter @adventure/contracts build && pnpm --filter @adventure/scoring build && turbo run dev --parallel",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "docker:up": "docker compose --env-file infra/.osm-region.env -f infra/docker-compose.yml up -d",
    "docker:down": "docker compose --env-file infra/.osm-region.env -f infra/docker-compose.yml down",
    "db:migrate": "pnpm --filter @adventure/api prisma:migrate",
    "db:seed": "pnpm --filter @adventure/api prisma:seed",
    "fetch:osm": "bash infra/scripts/fetch-osm.sh https://download.geofabrik.de/north-america/us/vermont-latest.osm.pbf vermont-latest.osm.pbf",
    "fetch:osm:url": "bash infra/scripts/fetch-osm.sh",
    "osm:use": "bash infra/scripts/use-osm-region.sh"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.2",
    "eslint": "^10.2.0",
    "prettier": "^3.5.3",
    "turbo": "^2.9.4",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  }
}
